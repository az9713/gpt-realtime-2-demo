# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_TRANSLATE_MODEL=gpt-realtime-translate
OPENAI_WHISPER_MODEL=gpt-realtime-whisper
OPENAI_VOICE=alloy

# --- Twilio (phone bridge) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Cockpit operator auth (single-tenant v1) ---
COCKPIT_OPERATOR_USER=operator
COCKPIT_OPERATOR_PASSWORD=change-me

# --- Postgres ---
POSTGRES_USER=cockpit
POSTGRES_PASSWORD=cockpit-dev-pw
POSTGRES_DB=cockpit
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Service ports ---
CORE_PORT=8000
EDGE_PORT=8080
FRONTEND_PORT=5173

# --- Public base URL (Twilio webhooks reach this) ---
PUBLIC_BASE_URL=http://localhost:8080

# --- Logging / tracing ---
LOG_LEVEL=info
TRACE_BATCH_SIZE=50
TRACE_BATCH_INTERVAL_MS=500

# --- Vertical default ---
DEFAULT_VERTICAL=hvac

# --- Phone-number → vertical mapping (CSV: number=vertical,number=vertical) ---
PHONE_VERTICAL_MAP=
